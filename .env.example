# ─── Database ───
DATABASE_URL=sqlite:///gaming_pr.db
# For PostgreSQL: DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gaming_pr

# ─── Server ───
PORT=8000
CORS_ORIGINS=
# Comma-separated allowed origins. Leave empty for wildcard (dev only).
# Example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ─── Authentication ───
JWT_SECRET_KEY=
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# If not set, a random key is generated per deploy (tokens invalidated on restart).
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ─── Scraping ───
SCRAPE_INTERVAL_MINUTES=30
SCRAPE_CONCURRENCY=5
SCRAPE_REQUEST_TIMEOUT=20
SCRAPE_RATE_LIMIT_DELAY=1.0
FULL_CONTENT_EXTRACTION=true
RESPECT_ROBOTS_TXT=true
ENABLE_SITEMAP_DISCOVERY=true
DEDUP_SIMILARITY_THRESHOLD=0.85

# ─── Advanced Scraping Features ───
ENABLE_BROWSER_FALLBACK=true
ENABLE_STEALTH_HEADERS=true
ENABLE_CIRCUIT_BREAKER=true
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=300
ENABLE_RETRY_QUEUE=true
RETRY_MAX_ATTEMPTS=3
ENABLE_ADAPTIVE_SCHEDULING=true
ENABLE_WEBHOOKS=true
ENABLE_CHANGE_TRACKING=true

# ─── Translation ───
TRANSLATION_PROVIDER=google

# ─── Email Service (external) ───
EMAIL_SERVICE_URL=http://localhost:3000
EMAIL_SERVICE_API_KEY=
